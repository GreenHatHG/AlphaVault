# RSS（多个用逗号或换行）
RSS_URLS=

# 定时（推荐：简化 cron）："*/15 6-22 * * *"
RSS_CRON=
SYNC_CRON=

# LLM（如果你用 OpenAI 兼容接口）
OPENAI_BASE_URL=
OPENAI_API_KEY=

# AI（推荐统一走这一套环境变量；如果不填 AI_API_KEY，会继续用 OPENAI_API_KEY / GEMINI_API_KEY）
AI_API_STYLE=litellm
AI_API_TYPE=openai
AI_MODEL=openai/gpt-5.2
AI_BASE_URL=
AI_API_MODE=responses
AI_STREAM=1
AI_TIMEOUT_SEC=1000
AI_REASONING_EFFORT=xhigh
AI_RPM=12
AI_RETRIES=11
AI_MAX_INFLIGHT=30
AI_TRACE_OUT=/data/trace.txt

# Turso（云端归档库）
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Streamlit（cloud=读 Turso；local=读本地 sqlite）
STREAMLIT_DB_MODE=cloud

# 只在 local 模式需要（Docker 里一般是 /data/workdb.sqlite）
WORKDB_SQLITE_PATH=/data/workdb.sqlite

# 本地数据保留（按 ingested_at=抓到时间；默认 10 天）
WORKDB_RETENTION_DAYS=10
WORKDB_CLEANUP_INTERVAL_SECONDS=3600
